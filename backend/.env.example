# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Orígenes permitidos en CORS (separados por coma, sin espacios)
# Ejemplo producción: https://ush.edu.co,https://www.ush.edu.co
ALLOWED_ORIGINS=http://localhost:5173

# ── Base de datos PostgreSQL ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ush_chatbot
DB_USER=postgres
DB_PASSWORD=CAMBIA_ESTO

# Opcionales — ajusta según el proveedor cloud
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000

# ── ChromaDB (vector store) ────────────────────────────────────────────────────
CHROMA_URL=http://localhost:8000

# Parámetros RAG (opcionales, los defaults son adecuados para producción)
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# ── Google Gemini ──────────────────────────────────────────────────────────────
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=CAMBIA_ESTO

# ── Autenticación JWT ──────────────────────────────────────────────────────────
# Genera un secreto seguro: openssl rand -hex 64
JWT_SECRET=CAMBIA_ESTO_usa_openssl_rand_hex_64
JWT_EXPIRES_IN=8h

# ── WhatsApp Business API (opcional) ──────────────────────────────────────────
# Solo necesario si activas la integración de WhatsApp
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
