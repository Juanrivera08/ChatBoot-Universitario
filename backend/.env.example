# ── Servidor ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Orígenes permitidos en CORS (separados por coma, sin espacios)
# Ejemplo producción: https://ush.edu.co,https://www.ush.edu.co
ALLOWED_ORIGINS=http://localhost:5173

# ── Base de datos PostgreSQL ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ush_chatbot
DB_USER=postgres
DB_PASSWORD=CAMBIA_ESTO

# Opcionales — ajusta según el proveedor cloud
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000

# ── ChromaDB (vector store) ────────────────────────────────────────────────────
CHROMA_URL=http://localhost:8000

# Parámetros RAG (opcionales, los defaults son adecuados para producción)
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# ── Flujos Guiados (desactivado por defecto) ──────────────────────────────────
# Módulo de flujos conversacionales guiados. Apagado mientras no se necesite.
# Ponlo en true para reactivar la intercepción de flujos (chat web + WhatsApp).
# Recuerda también descomentar la pestaña/ruta de admin en el frontend.
FLOWS_ENABLED=false

# ── Google Gemini ──────────────────────────────────────────────────────────────
# Obtén tu clave en: https://aistudio.google.com/app/apikey
# NUNCA pongas la clave real en este archivo — solo en .env (que está en .gitignore)
GOOGLE_API_KEY=CAMBIA_ESTO

# ── Autenticación JWT ──────────────────────────────────────────────────────────
# Genera un secreto criptográficamente seguro (mínimo 64 bytes):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NUNCA uses una frase predecible como "secreto_2024"
JWT_SECRET=CAMBIA_ESTO_ejecuta_node_crypto_randomBytes_64
JWT_EXPIRES_IN=8h

# ── WhatsApp Business API (opcional) ──────────────────────────────────────────
# Solo necesario si activas la integración de WhatsApp
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# App Secret de tu app en Meta Developers — requerido para verificar firma del webhook
WHATSAPP_APP_SECRET=
