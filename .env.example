# ============================================================
# VARIABLES DE ENTORNO — CHATBOT USH
# Copia este archivo a .env y llena los valores reales.
# docker-compose lee este archivo automáticamente.
# NUNCA subas .env a git.
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DB_NAME=ush_chatbot
DB_USER=postgres
DB_PASSWORD=           # ← CAMBIAR — contraseña segura

# ── Google Gemini ─────────────────────────────────────────────
# Genera una clave en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=        # ← CAMBIAR

# ── JWT ───────────────────────────────────────────────────────
# Genera un secreto seguro (mínimo 64 bytes):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=            # ← CAMBIAR
JWT_EXPIRES_IN=8h

# ── CORS ──────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (sin espacios)
# Ejemplo producción: https://ush.edu.co,https://www.ush.edu.co
ALLOWED_ORIGINS=http://localhost

# ── Logs ──────────────────────────────────────────────────────
LOG_LEVEL=info

# ── WhatsApp Business API (opcional) ─────────────────────────
# Solo si activas la integración de WhatsApp
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# App Secret de Meta Developers — requerido para verificar firma del webhook
WHATSAPP_APP_SECRET=
